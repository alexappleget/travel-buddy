{
  "name": "mf-react-rsbuild",
  "version": "1.0.0",
  "description": "Rsbuild Module Federation example with Zephyr",
  "private": true,
  "scripts": {
    "build": "pnpm build-auth && pnpm build-shell",
    "build-auth": "pnpm --filter=mf-react-rsbuild-auth build",
    "build-shell": "pnpm --filter=mf-react-rsbuild-shell build",
    "dev": "pnpm --filter=mf-react-rsbuild-auth dev & pnpm --filter=mf-react-rsbuild-shell dev"
  },
  "keywords": [
    "rsbuild",
    "module-federation",
    "zephyr"
  ],
  "author": "",
  "license": "MIT"
}
